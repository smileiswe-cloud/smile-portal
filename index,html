<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Smile Portal</title>
    <style>
        body {
            font-family: system-ui, -apple-system, sans-serif;
            background: #f8f9fa;
            padding: 20px;
            text-align: center;
        }
        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 40px 20px;
            border-radius: 20px;
            margin-bottom: 20px;
        }
        .loading {
            color: #666;
            padding: 40px;
        }
        .error {
            color: red;
            padding: 20px;
            background: #fee;
            border-radius: 10px;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>✨ Smile Portal</h1>
        <p>Mobile & Cosmetics</p>
    </div>
    <div id="content">
        <div class="loading">Loading...</div>
    </div>

    <script>
        // ⚠️ သင့် Apps Script URL နဲ့ အစားထိုးပါ
        const API_URL = 'https://script.google.com/macros/s/AKfycbxm4_jlIHyGLIxy9x03MXjBqvnY_u_lzA8JgV6mi8ZvEmGd2bv-6Js-Czl1HJigHyYo/exec';
        
        async function fetchData() {
            try {
                const response = await fetch(API_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: 'getData' })
                });
                const data = await response.json();
                document.getElementById('content').innerHTML = '<div class="loading">✅ Connected! Data loaded: ' + data.length + ' items</div>';
            } catch(err) {
                document.getElementById('content').innerHTML = '<div class="error">❌ Connection error: ' + err.message + '</div>';
            }
        }
        
        fetchData();
    </script>
</body>
</html>
