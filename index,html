    <div id="loginModal" class="modal"><div class="modal-content"><h3>System Access</h3><input type="text" id="uName" class="form-input" placeholder="Username"><input type="password" id="pWord" class="form-input" placeholder="Password"><button class="btn btn-primary" onclick="doLogin()">Login</button><button class="btn btn-secondary" onclick="closeModal('loginModal')">Close</button></div></div>

    <div id="addModal" class="modal">
