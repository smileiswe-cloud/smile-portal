    <script>
      var API_URL = https://script.google.com/macros/s/AKfycbxybzy94UqoyoanEFqr_XraZm_Pu7Fsf5oyaf7blOZqaroCaK2FyJ1FB3f531r4oZc/exec;
      var allData = [], userRole = null, selectedItem = null, systemSettings = {}, selectedDeliType = 'COD';
      var currentCategory = 'all';
      
      window.onload = function() {
        var d = new Date();
        var ms = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
        document.getElementById('currentDate').innerText = "📅 "+d.getDate()+" "+ms[d.getMonth()]+" "+d.getFullYear();
        fetchData();
      };
      
      async function fetchData() {
        document.getElementById('loading').style.display = 'block';
        try {
          var response = await fetch(API_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'getData' })
          });
          var data = await response.json();
          initData(data);
          
          // Also fetch settings
          var settingsRes = await fetch(API_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'getSettings' })
          });
          systemSettings = await settingsRes.json();
          
        } catch(err) {
          console.error("Fetch error:", err);
          document.getElementById('loading').innerHTML = '❌ Connection error. Please refresh.';
        }
      }
      
      function initData(d) {
        allData = d;
        document.getElementById('loading').style.display = 'none';
        updateBrandFilter();
        renderList();
      }
      
      function updateBrandFilter() {
        var brands = [...new Set(allData.map(r => r[1]))];
        var select = document.getElementById('brandFilter');
        select.innerHTML = '<option value="All">All Brands</option>';
        brands.forEach(b => {
          if(b) {
            var o = document.createElement('option');
            o.value = b;
            o.innerHTML = b;
            select.appendChild(o);
          }
        });
      }
      
      function setCategory(cat) {
        currentCategory = cat;
        document.querySelectorAll('.cat-tab').forEach(tab => {
          tab.classList.remove('active');
        });
        document.querySelector(`.cat-tab[data-cat="${cat}"]`).classList.add('active');
        if(cat === 'Cosmetic') {
          document.querySelector(`.cat-tab[data-cat="Cosmetic"]`).classList.add('active');
        }
        filterData();
      }
      
      function filterData() {
        var searchTerm = document.getElementById('searchInput').value.toLowerCase();
        var brand = document.getElementById('brandFilter').value;
        var filtered = allData.filter(item => {
          var matchesCategory = true;
          if(currentCategory !== 'all') {
            matchesCategory = item[0] === currentCategory;
          }
          var matchesBrand = (brand === 'All' || item[1] === brand);
          var matchesSearch = (item[1] + " " + item[2] + " " + item[3]).toLowerCase().includes(searchTerm);
          return matchesCategory && matchesBrand && matchesSearch;
        });
        renderList(filtered);
      }
      
      function formatMoney(n) { return n ? n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",") : ""; }
      
      function renderList(data) {
        var h = '';
        data.forEach((r, i) => {
          var imgs = (r[9] ? r[9].toString() : 'https://via.placeholder.com/400x400').split(',');
          var sh = '', dh = '';
          if(imgs.length > 1) {
            imgs.forEach((u,k) => { sh += `<img src="${u.trim()}" class="card-img" loading="lazy">`; dh += `<div class="dot ${k===0?'active':''}"></div>`; });
          } else {
            sh = `<img src="${imgs[0].trim()}" class="card-img" loading="lazy">`;
          }
          var ch = r[8] ? `<select class="color-select" id="cSelect_${i}">${r[8].split(',').map(c => `<option>${c.trim()}</option>`).join('')}</select>` : '';
          var ad = (userRole === 'admin') ? 'flex' : 'none';
          var isCosmetic = r[0] === 'Cosmetic';
          var priceColor = isCosmetic ? '#ec008c' : 'var(--primary)';
          h += `<div class="card"><div class="card-actions" style="display:${ad}"><button class="action-btn edit-btn" onclick="openEditModal(${i})">✎</button><button class="action-btn del-btn" onclick="confirmDelete(${i})">🗑</button></div><div class="slider-container"><div class="image-slider" onscroll="updateDots(this)">${sh}</div><div class="slider-dots">${dh}</div></div><div class="card-body"><div class="brand-tag">${r[1]}</div><div class="model-name">${r[2]}</div><div class="badge-container">${r[6]?`<span class="badge badge-discount">${r[6]}</span>`:''}${r[7]?`<span class="badge badge-cashback">${r[7]}</span>`:''}${isCosmetic?'<span class="badge badge-cosmetic">💄 Cosmetic</span>':''}${r[10]?`<span class="badge badge-note">${r[10]}</span>`:''}</div><div class="model-spec">${r[3]}</div>${ch}<div class="price-area"><div class="price-text">${r[5]?`<span class="normal-price">${formatMoney(r[5])}</span>`:''}<span class="sell-price" style="color:${priceColor};">${formatMoney(r[4])} Ks</span></div><button class="order-btn" onclick="openOrderModal(${i})">Order Now</button></div></div></div>`;
        });
        document.getElementById('content').innerHTML = h || '<div style="text-align:center; padding:40px;">No products found.</div>';
      }
      
      function updateDots(s) {
        var c = s.closest('.slider-container');
        var a = Math.round(s.scrollLeft / s.offsetWidth);
        c.querySelectorAll('.dot').forEach((d,i) => { if(i===a) d.classList.add('active'); else d.classList.remove('active'); });
      }
      
      function toggleContactMenu() { document.getElementById('contactMenu').classList.toggle('show'); }
      document.addEventListener('click', function(e) { if(!document.querySelector('.contact-widget').contains(e.target)) document.getElementById('contactMenu').classList.remove('show'); });
      
      // Admin Logic
      function openLogin() { document.getElementById('loginModal').style.display = 'flex'; }
      function closeModal(id) { document.getElementById(id).style.display = 'none'; }
      
      async function doLogin() {
        var u = document.getElementById('uName').value;
        var p = document.getElementById('pWord').value;
        try {
          var response = await fetch(API_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'checkLogin', username: u, password: p })
          });
          var result = await response.json();
          if(result.status === 'success') {
            closeModal('loginModal');
            userRole = result.role;
            var s = result.shop ? " (" + result.shop + ")" : "";
            document.getElementById('loginStatus').innerText = "User: " + u.toUpperCase() + s;
            if(userRole === 'admin' || userRole === 'staff') document.getElementById('addBtn').style.display = 'block';
            filterData();
          } else { alert('Login Failed'); }
        } catch(err) { alert('Error: ' + err.message); }
      }
      
      function openAddModal() {
        document.getElementById('addModal').style.display = 'flex';
        document.getElementById('editMode').value = 'false';
        document.getElementById('modalTitle').innerText = "Add New";
        document.getElementById('saveBtn').innerText = "Save";
        document.querySelectorAll('#addModal input:not([type=checkbox]),#addModal textarea,#addModal select').forEach(i => {
          if(i.type !== 'hidden' && i.id !== 'nCategory') i.value = '';
        });
        document.getElementById('nCategory').value = 'Mobile';
        document.getElementById('nHot').checked = false;
      }
      
      function openEditModal(index) {
        var searchTerm = document.getElementById('searchInput').value.toLowerCase();
        var brand = document.getElementById('brandFilter').value;
        var filtered = allData.filter(item => {
          var matchesCategory = currentCategory === 'all' || item[0] === currentCategory;
          var matchesBrand = brand === 'All' || item[1] === brand;
          var matchesSearch = (item[1] + " " + item[2] + " " + item[3]).toLowerCase().includes(searchTerm);
          return matchesCategory && matchesBrand && matchesSearch;
        });
        var it = filtered[index];
        document.getElementById('addModal').style.display = 'flex';
        document.getElementById('editMode').value = 'true';
        document.getElementById('modalTitle').innerText = "Edit Item";
        document.getElementById('saveBtn').innerText = "Update";
        document.getElementById('nCategory').value = it[0];
        document.getElementById('nBrand').value = it[1];
        document.getElementById('nModel').value = it[2];
        document.getElementById('nSpec').value = it[3];
        document.getElementById('nPrice').value = it[4];
        document.getElementById('nNormal').value = it[5];
        document.getElementById('nDisc').value = it[6];
        document.getElementById('nCash').value = it[7];
        document.getElementById('nColors').value = it[8];
        document.getElementById('nImg').value = it[9];
        document.getElementById('nNote').value = it[10];
        document.getElementById('nHot').checked = (it[11] === 'Yes');
        document.getElementById('oldBrand').value = it[1];
        document.getElementById('oldModel').value = it[2];
        document.getElementById('oldSpec').value = it[3];
      }
      
      async function confirmDelete(index) {
        if(!confirm("Are you sure?")) return;
        var searchTerm = document.getElementById('searchInput').value.toLowerCase();
        var brand = document.getElementById('brandFilter').value;
        var filtered = allData.filter(item => {
          var matchesCategory = currentCategory === 'all' || item[0] === currentCategory;
          var matchesBrand = brand === 'All' || item[1] === brand;
          var matchesSearch = (item[1] + " " + item[2] + " " + item[3]).toLowerCase().includes(searchTerm);
          return matchesCategory && matchesBrand && matchesSearch;
        });
        var it = filtered[index];
        try {
          var response = await fetch(API_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'deleteItem', category: it[0], brand: it[1], model: it[2], spec: it[3] })
          });
          var result = await response.json();
          alert(result.message);
          fetchData();
        } catch(err) { alert('Error: ' + err.message); }
      }
      
      async function submitItem() {
        var isEdit = document.getElementById('editMode').value === 'true';
        var category = document.getElementById('nCategory').value;
        var brand = document.getElementById('nBrand').value;
        var model = document.getElementById('nModel').value;
        var spec = document.getElementById('nSpec').value;
        var price = document.getElementById('nPrice').value;
        var normalPrice = document.getElementById('nNormal').value;
        var discount = document.getElementById('nDisc').value;
        var cashback = document.getElementById('nCash').value;
        var colors = document.getElementById('nColors').value;
        var images = document.getElementById('nImg').value;
        var note = document.getElementById('nNote').value;
        var hot = document.getElementById('nHot').checked ? 'Yes' : 'No';
        
        if(!brand || !model || !price) { alert('Missing required fields'); return; }
        
        var btn = document.getElementById('saveBtn');
        btn.innerText = "..."; btn.disabled = true;
        
        try {
          var body;
          if(isEdit) {
            body = { action: 'editItem', oldCategory: document.getElementById('oldBrand').value, oldBrand: document.getElementById('oldBrand').value, oldModel: document.getElementById('oldModel').value, oldSpec: document.getElementById('oldSpec').value, category: category, brand: brand, model: model, spec: spec, price: price, normalPrice: normalPrice, discount: discount, cashback: cashback, colors: colors, images: images, note: note, hot: hot };
          } else {
            body = { action: 'addItem', category: category, brand: brand, model: model, spec: spec, price: price, normalPrice: normalPrice, discount: discount, cashback: cashback, colors: colors, images: images, note: note, hot: hot };
          }
          var response = await fetch(API_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
          });
          var result = await response.json();
          alert(result.message);
          closeModal('addModal');
          fetchData();
        } catch(err) { alert('Error: ' + err.message); }
        btn.innerText = isEdit ? "Update" : "Save"; btn.disabled = false;
      }
      
      // Order Logic
      function openOrderModal(index) {
        var searchTerm = document.getElementById('searchInput').value.toLowerCase();
        var brand = document.getElementById('brandFilter').value;
        var filtered = allData.filter(item => {
          var matchesCategory = currentCategory === 'all' || item[0] === currentCategory;
          var matchesBrand = brand === 'All' || item[1] === brand;
          var matchesSearch = (item[1] + " " + item[2] + " " + item[3]).toLowerCase().includes(searchTerm);
          return matchesCategory && matchesBrand && matchesSearch;
        });
        selectedItem = filtered[index];
        var colorSelect = document.getElementById(`cSelect_${index}`);
        var selectedColor = colorSelect ? colorSelect.value : '';
        document.getElementById('orderModal').style.display = 'flex';
        document.getElementById('orderSummary').innerHTML = `<b>${selectedItem[1]} ${selectedItem[2]}</b><br>${selectedItem[3]}<br>Price: ${formatMoney(selectedItem[4])} Ks`;
        document.getElementById('oColor').value = selectedColor;
        selectDeli('COD');
      }
      
      function selectDeli(t) {
        selectedDeliType = t;
        document.getElementById('optCOD').className = (t === 'COD') ? 'deli-option selected' : 'deli-option';
        document.getElementById('optPOD').className = (t === 'POD') ? 'deli-option selected' : 'deli-option';
        var ik = (t === 'COD') ? 'cod_image' : 'pod_image';
        var tk = (t === 'COD') ? 'cod_note' : 'pod_note';
        document.getElementById('deliImg').src = systemSettings[ik] || 'https://via.placeholder.com/300x200';
        document.getElementById('deliNote').innerHTML = systemSettings[tk] || '...';
        document.getElementById('payAcc').innerHTML = systemSettings['payment_acc'] || '';
      }
      
      async function sendOrder() {
        var name = document.getElementById('oName').value;
        var phone = document.getElementById('oPhone').value;
        var address = document.getElementById('oAddress').value;
        var color = document.getElementById('oColor').value;
        var note = document.getElementById('oNote').value;
        if(!name || !phone || !address) { alert('Please fill required fields'); return; }
        var btn = document.getElementById('sendOrderBtn');
        btn.innerText = "Sending..."; btn.disabled = true;
        var orderData = {
          action: 'receiveOrder',
          name: name, phone: phone, address: address, color: color, note: note,
          deliType: selectedDeliType,
          paymentNote: (selectedDeliType === 'COD') ? systemSettings['cod_text'] : systemSettings['pod_text'],
          model: selectedItem[1] + " " + selectedItem[2],
          spec: selectedItem[3],
          price: formatMoney(selectedItem[4]) + " Ks"
        };
        try {
          var response = await fetch(API_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(orderData)
          });
          var result = await response.json();
          alert("Order placed successfully!");
          closeModal('orderModal');
          document.getElementById('oName').value = '';
          document.getElementById('oPhone').value = '';
          document.getElementById('oAddress').value = '';
          document.getElementById('oNote').value = '';
        } catch(err) { alert('Error: ' + err.message); }
        btn.innerText = "Confirm Order"; btn.disabled = false;
      }
    </script>
  </body>
</html>
